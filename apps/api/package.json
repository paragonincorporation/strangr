{
  "name": "@strangr/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "lint": "eslint src vitest.config.ts --max-warnings 0",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/server.js",
    "start:worker": "node dist/worker.js"
  },
  "dependencies": {
    "@fastify/swagger": "^9.8.0",
    "@fastify/swagger-ui": "^6.1.0",
    "@strangr/config": "^0.0.0",
    "@strangr/contracts": "^0.0.0",
    "@supabase/supabase-js": "^2.110.2",
    "fastify": "^5.10.0",
    "jose": "^6.2.3",
    "redis": "^5.12.1",
    "sharp": "^0.35.3",
    "ws": "^8.21.0",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/ws": "^8.18.1",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3"
  }
}
